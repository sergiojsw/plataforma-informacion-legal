# Base de datos PostgreSQL
# Para desarrollo con Docker: postgresql://postgres:postgres@localhost:5432/legal_db
# Para producción con Neon: postgresql://user:pass@host/database?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/legal_db"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secreto-seguro-con-openssl-rand-base64-32"

# Groq API (GRATUITO - para el chat con IA)
# Obtener en https://console.groq.com (gratis, sin tarjeta de crédito)
GROQ_API_KEY="gsk_..."

# Resend (para newsletters) - Opcional
# Obtener en https://resend.com
RESEND_API_KEY="re_..."
