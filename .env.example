# Base de datos PostgreSQL
# Para desarrollo con Docker: postgresql://postgres:postgres@localhost:5432/legal_db
# Para producción con Neon: postgresql://user:pass@host/database?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/legal_db"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secreto-seguro-con-openssl-rand-base64-32"

# ============================================
# PROVEEDORES DE IA - TODOS GRATUITOS
# ============================================

# Google Gemini (GRATIS - 1500 req/dia)
# Obtener en https://aistudio.google.com/apikey
GEMINI_API_KEY="..."

# Groq (GRATIS - 30 req/min, muy rapido)
# Obtener en https://console.groq.com/keys
GROQ_API_KEY=""

# Cohere (GRATIS - 1000 req/mes)
# Obtener en https://dashboard.cohere.com/api-keys
COHERE_API_KEY=""

# Resend (para newsletters) - Recomendado para envio de boletines
# Obtener en https://resend.com
RESEND_API_KEY="re_..."

# Email remitente para newsletters
EMAIL_FROM="Plataforma Legal <noreply@tudominio.com>"

# Seguridad para Cron Jobs de Vercel
# Generar con: openssl rand -base64 32
CRON_SECRET="genera-un-secreto-para-cron-jobs"
