generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  nombre       String
  rol          Role          @default(USUARIO)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatHistory  ChatHistory[]
}

enum Role {
  ADMIN
  USUARIO
}

model Documento {
  id        String    @id @default(cuid())
  titulo    String
  categoria Categoria
  resumen   String    @db.Text
  contenido String    @db.Text
  enlace    String?
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Categoria {
  LEGISLACION
  JURISPRUDENCIA
  DOCTRINA
  PRACTICA_JURIDICA
}

model Newsletter {
  id        String         @id @default(cuid())
  tipo      TipoNewsletter
  asunto    String
  contenido String         @db.Text
  enviadoAt DateTime?
  createdAt DateTime       @default(now())
}

enum TipoNewsletter {
  DIARIO
  SEMANAL
}

model ChatHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pregunta  String   @db.Text
  respuesta String   @db.Text
  createdAt DateTime @default(now())
}
