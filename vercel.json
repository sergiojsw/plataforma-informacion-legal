{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/noticias",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/newsletter-diario",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/cron/newsletter-semanal",
      "schedule": "0 10 * * 1"
    }
  ]
}
